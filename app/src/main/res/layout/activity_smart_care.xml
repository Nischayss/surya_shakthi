<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Smart Care &amp; ROI"
            android:textColor="@color/yellow_400"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- 1. ROI Tracker Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰 Payback Tracker (ROI)"
                    android:textColor="@color/yellow_400"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tv_payback_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System is 0% Paid Off"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <ProgressBar
                    android:id="@+id/payback_progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/battery_progress_drawable"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:id="@+id/tv_total_saved_roi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Saved: ₹0"
                        android:textColor="@color/green_500"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_remaining_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Left: ₹0"
                        android:textColor="@color/red_400"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_set_cost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Update Total System Cost"
                    android:textColor="@color/black"
                    app:backgroundTint="@color/yellow_400"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 2. Solar Forecast Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌤️ Tomorrow's Forecast"
                    android:textColor="@color/yellow_400"
                    android:textSize="15sp"
                    android:textStyle="bold" android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tv_forecast_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading prediction..."
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 3. Maintenance Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:text="🧼 Panel Maintenance"
                        android:textColor="@color/yellow_400"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <ImageButton
                        android:id="@+id/btn_delete_maintenance"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_delete"
                        app:tint="@color/red_400"
                        android:padding="4dp"
                        android:scaleType="fitCenter"/>
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tv_last_cleaned"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Last cleaned: Not recorded"
                        android:textColor="?android:attr/textColorPrimary"
                        android:textSize="14sp"/>

                    <ImageButton
                        android:id="@+id/btn_pick_cleaned_date"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        app:tint="@color/yellow_400"
                        android:contentDescription="Select Date"
                        android:padding="8dp"
                        android:scaleType="fitCenter"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btn_mark_cleaned"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mark as Cleaned Today"
                    android:textColor="@color/black"
                    app:backgroundTint="@color/yellow_400"
                    style="@style/Widget.MaterialComponents.Button"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 4. Quick Alerts -->
        <Button
            android:id="@+id/btn_send_peak_alert"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="🔔 Send Peak Sun Alert"
            android:textColor="@color/black"
            app:backgroundTint="@color/yellow_400"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.Button"/>

    </LinearLayout>
</ScrollView>
